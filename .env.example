# Copia este archivo a .env.local y completa los valores.
# .env.local está en .gitignore — nunca se sube al repo.

# Neon (console.neon.tech > tu proyecto > Connect > Connection string)
# Usa la connection string "pooled" que Neon muestra por defecto.
# Solo se usa en el servidor (scripts y route handlers) — nunca en el navegador.
DATABASE_URL=postgresql://usuario:password@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require

# OpenAI (https://platform.openai.com/api-keys)
OPENAI_API_KEY=
