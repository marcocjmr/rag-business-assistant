# Copia este archivo a .env.local y completa los valores.
# .env.local está en .gitignore — nunca se sube al repo.

# Supabase (Dashboard > Settings > API)
SUPABASE_URL=https://tu-proyecto.supabase.co
# Service role key: solo se usa en el servidor (scripts y route handlers).
# NUNCA la expongas al navegador (no usar prefijo NEXT_PUBLIC_).
SUPABASE_SERVICE_ROLE_KEY=

# OpenAI (https://platform.openai.com/api-keys)
OPENAI_API_KEY=
